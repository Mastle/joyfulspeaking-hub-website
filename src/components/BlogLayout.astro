---
const allPostContent = await Astro.glob(`../content/en/*/*.md`);

const { blogPostTitle, blogAuthor } = Astro.props;
const newBlogPostTitle = blogPostTitle.replaceAll("-", " ");
---

{
    allPostContent.map((post) => {
        if (
            post.frontmatter.title.toLowerCase() === newBlogPostTitle &&
            post.frontmatter.instructor.toLowerCase() === blogAuthor
        ) {
            return (
                <div class="position-relative pb-5">
                    <h2 class="mt-5 pt-5 fw-bold">{post.frontmatter.title}</h2>
                    <p class="text-secondary pt-1">{post.frontmatter.date}</p>
                    <p class="text-secondary pt-1 mb-1">
                        <i class="fa-solid fa-user-pen py-1 pe-2">
                        </i>{(post.frontmatter.instructor === "Amirali")
                         ? "Amirali Taqishah": "Sareh Ranjbar"}</p>
                         <span class="d-block text-secondary"><i class="fa-brands fa-readme py-1 pe-2"></i>{post.frontmatter.readtime}</span>
                         <span class="text-secondary">Series: </span>
                    <span class="rounded p-2 fst-italic">
                       {post.frontmatter.blogSeriesName}
                    </span>
                     <a class={`${post.frontmatter.hasSummary ? "d-block": "d-none"} text-primary ps-1`} href="#summary-section">View Summary Highlights </a>
                    <div class="pt-5" set:html={post.compiledContent()} />
                </div>
            );
        }
    })
}
