---
const allPostContent = await Astro.glob(`../content/fa/*/*.md`);

const { blogPostTitle, blogAuthor } = Astro.props;
const newBlogPostTitle = blogPostTitle.replaceAll("-", " ");
---

{
    allPostContent.map((post) => {
        if (
            post.frontmatter.title.toLowerCase() === newBlogPostTitle &&
            post.frontmatter.instructor.toLowerCase() === blogAuthor
        ) {
            return (
                <div class="position-relative pb-5 text-end">
                    <h2 class="mt-5 pt-5 fw-bold"> {post.frontmatter.persianTitle}</h2>
                    <p class="text-secondary pt-1">{post.frontmatter.date}</p>
                    <p class="text-secondary pt-1 mb-1">
                        {(post.frontmatter.instructor === "Amirali")
                         ? "امیرعلی تقی شاه": "ساره رنجبر"}<i class="fa-solid fa-user-pen py-1 ps-2">
                        </i></p>
                        <span class="d-block text-secondary">{post.frontmatter.readtime}<i class="fa-brands fa-readme py-1 ps-2"></i></span>
                        <div>
                          <span class="text-secondary">دوره: </span>
                          <span class="rounded p-2">
                            {post.frontmatter.blogSeriesName}
                          </span>
                        </div>
                        <a class={`${post.frontmatter.hasSummary ? "d-block": "d-none"} text-primary ps-1`} href="#summary-section">چکیده مقاله </a>
                    <div class="pt-5" set:html={post.compiledContent()} />
                </div>
            );
        }
    })
}
