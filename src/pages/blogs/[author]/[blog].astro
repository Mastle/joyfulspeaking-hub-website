---
import "../../../assets/styles/main.css";
import "../../../assets/styles/persianFont.css";
import favicon from "../../../assets/js_favicon.svg";
import BlogLayoutFa from "../../../components/BlogLayoutFa.astro";
import Navbar from "../../../components/Navbar.astro";
import Footer from "../../../components/Footer.astro";
export function getStaticPaths() {
    return [
        { params: { author: "amirali", blog: "the-very-first-step" } },
        {
            params: {
                author: "amirali",
                blog: "class-formats-explained",
            },
        },
    ];
}

const { blog, author } = Astro.params;
---

<html>
  <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href={favicon} />
        <script
            src="https://kit.fontawesome.com/7ba95182a4.js"
            crossorigin="anonymous"></script>
        <title>Joyful Speaking</title>
  </head>
    <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-DS5TEBPBKQ"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-DS5TEBPBKQ');
  </script>
  <body>
        <main>
            <Navbar
                isHome={false}
                learnAddress="../../../#learn"
                questionAddress="../../../#questions"
            />
            <div class="container max-width-1000 px-4">
                <BlogLayoutFa blogPostTitle={blog} blogAuthor={author} />
            </div>
            <Footer />
        </main>

        <style>
       
            body {
                font-size: 1.16rem;
                line-height: 1.625;
            }
        </style>
        <script
            src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.1/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-gtEjrD/SeCtmISkJkNUaaKMoLD0//ElJ19smozuHV6z3Iehds+3Ulb9Bn9Plx0x4"
            crossorigin="anonymous"></script>
  </body>
</html>
